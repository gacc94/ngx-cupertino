{
    "name": "@ngx-cupertino/core",
    "version": "0.6.0-alpha.1",
    "description": "Core utilities, services, types, and base classes for @ngx-cupertino",
    "sass": "./_index.scss",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gacc94/ngx-cupertino.git",
        "directory": "libs/core"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "angular",
        "cupertino",
        "core",
        "ios",
        "macos",
        "apple"
    ],
    "scripts": {
        "docs": "typedoc"
    },
    "peerDependencies": {
        "@angular/cdk": ">=21.0.0",
        "@angular/common": ">=21.0.0",
        "@angular/core": ">=21.0.0",
        "@angular/forms": ">=21.0.0",
        "@ngx-cupertino/tokens": ">=0.1.0-alpha.1"
    },
    "exports": {
        ".": {
            "sass": "./_index.scss"
        },
        "./styles/mixins": {
            "sass": "./src/lib/styles/_mixins.scss"
        },
        "./styles/animations": {
            "sass": "./src/lib/styles/_animations.scss"
        }
    },
    "sideEffects": false
}
