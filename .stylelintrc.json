{
    "extends": "stylelint-config-standard-scss",
    "rules": {
        "selector-class-pattern": "^(cup(-[a-z][a-zA-Z0-9]*)*|filled|tinted|gray|plain|liquid-glass|destructive|sidebar|sidebar-header|sidebar-close-btn|sidebar-toggle-fab|sidebar-open|logo|main|demo-row|demo-section|active|sidebar-footer|disabled|checked|focused|error|filled|readonly|sm|lg|dragging|at-min|at-max|indeterminate|loading|full-width|icon-only|shape-capsule|shape-rounded|shape-circle|label-start|label|label-below|icon|spinner|spinner-line|track|fill|thumb|input|input-container|prefix|suffix|clear|helper|error-text|header|value|slider-row|min-icon|max-icon|track-container|ticks|tick|native|decrement|increment|controls|value-display|linear|circular|circular-track|circular-fill|info|percentage|type-linear|type-circular|type-spinner)$",
        "selector-max-id": 0,
        "no-descending-specificity": null,
        "color-function-alias-notation": null,
        "alpha-value-notation": "number",
        "custom-property-empty-line-before": null,
        "declaration-block-no-redundant-longhand-properties": null,
        "block-no-redundant-nested-style-rules": null,
        "declaration-block-no-duplicate-properties": null,
        "declaration-block-single-line-max-declarations": null,
        "media-feature-name-no-unknown": null,
        "property-no-deprecated": null,
        "scss/dollar-variable-pattern": null,
        "scss/at-mixin-pattern": null,
        "scss/at-function-pattern": null,
        "scss/percent-placeholder-pattern": null,
        "scss/selector-no-redundant-nesting-selector": true,
        "scss/at-extend-no-missing-placeholder": true,
        "scss/dollar-variable-empty-line-before": null,
        "scss/no-global-function-names": null,
        "scss/operator-no-newline-before": null,
        "property-no-vendor-prefix": null,
        "declaration-empty-line-before": null,
        "rule-empty-line-before": [
            "always-multi-line",
            {
                "except": ["first-nested"],
                "ignore": ["after-comment"]
            }
        ]
    }
}
